# Required on Railway. Use the Railway Postgres reference variable.
DATABASE_URL=postgresql://user:password@host:5432/north_star

# Required on Railway. Browser HTTP Basic Authentication protects every page and API route.
NORTH_STAR_USERNAME=stephen
NORTH_STAR_PASSWORD=replace-with-a-unique-password-of-at-least-16-characters

SYNC_SECRET=replace-with-a-long-random-secret
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=
IBKR_FLEX_OWNER=SMSF
SHARESIGHT_CLIENT_ID=
SHARESIGHT_CLIENT_SECRET=
SHARESIGHT_REDIRECT_URI=
MARKET_DATA_PROVIDER=
MARKET_DATA_API_KEY=

# Optional local-file development override. When DATABASE_URL is omitted locally,
# NorthStar stores data in .north-star/data.json.
# NORTH_STAR_DATA_FILE=/absolute/path/to/data.json
